            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"\",\n  \"instructor\": \"Prof. Test\",\n  \"duracionHoras\": 20,\n  \"costo\": 50000\n}"
            },
            "url": "{{baseUrl}}/api/cursos",
            "description": "Validacion Bean Validation.\nSQL: bloque ADMIN 06"
          }
        },
        {
          "name": "ADMIN 07 - Crear curso costo negativo (400)",
          "event": [
