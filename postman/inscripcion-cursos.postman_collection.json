          "name": "INFRA 01 - Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health",
            "description": "Esperado: 200 UP"
          }
        },
        {
          "name": "INFRA 02 - OpenAPI docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api-docs",
