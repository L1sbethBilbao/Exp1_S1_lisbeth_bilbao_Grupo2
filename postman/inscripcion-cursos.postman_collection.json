          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Curso Invalido\",\n  \"instructor\": \"Prof. Test\",\n  \"duracionHoras\": 20,\n  \"costo\": -100\n}"
            },
            "url": "{{baseUrl}}/api/cursos",
            "description": "Costo debe ser positivo.\nSQL: bloque ADMIN 07"
          }
        },
        {
          "name": "ADMIN 08 - Crear curso duplicado (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('409 Conflict', function () { pm.response.to.have.status(409); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Spring Boot Avanzado\",\n  \"instructor\": \"Prof. Garcia\",\n  \"duracionHoras\": 40,\n  \"costo\": 150000\n}"
            },
            "url": "{{baseUrl}}/api/cursos",
            "description": "Nombre ya existe.\nSQL: bloque ADMIN 08"
          }
        }
      ]
    },
