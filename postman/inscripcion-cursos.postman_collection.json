                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Microservicios con Spring\",\n  \"instructor\": \"Prof. Torres\",\n  \"duracionHoras\": 50,\n  \"costo\": 200000\n}"
            },
            "url": "{{baseUrl}}/api/cursos",
            "description": "Esperado: 201, id 5.\nSQL: bloque ADMIN 04"
          }
        },
        {
          "name": "ADMIN 05 - Listar cursos (despues de crear)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/cursos",
            "description": "Esperado: 200, 5 cursos en total.\nSQL: bloque ADMIN 05"
          }
        },
        {
          "name": "ADMIN 06 - Crear curso nombre vacio (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
